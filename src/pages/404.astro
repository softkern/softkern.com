---
import Button from '@components/common/Button.astro'
import Layout from '@layouts/Layout.astro'
---

<Layout title={"找不到了 - 404"} description="">
  <div
    class="flex flex-col items-center justify-center min-h-[60vh] text-center space-y-8"
  >
    <div class="space-y-4">
      <h1 class="heading text-6xl">404</h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 bg-base">
        抱歉！您访问的页面不存在。
      </p>
    </div>

    <div class="flex gap-4">
      <Button href={`/`} variant="primary"> 返回首页 </Button>
      <Button href={`/posts`}> 阅读博客 </Button>
    </div>
  </div>
</Layout>
