---
import development from '@data/development'
import hardware from '@data/hardware'
import software from '@data/software'
import BaseLayout from '@layouts/BaseLayout.astro'

const toolsets = [hardware, development, software]
---

<BaseLayout title="工具" description="我使用的工具和技术">
  <div class="space-y-12">
    <header class="space-y-4">
      <h1 class="heading text-4xl">常用工具</h1>
      <p class="text-gray-600 dark:text-gray-400 bg-base max-w-2xl">
        我在日常开发和工作中使用的硬件、软件和技术栈
      </p>
    </header>

    {
      toolsets.map(section => (
        <section class="space-y-6">
          <div class="space-y-2">
            <h2 class="heading text-2xl">{section.title}</h2>
            <p class="text-gray-600 dark:text-gray-400 bg-base">{section.description}</p>
          </div>

          <div class="grid gap-6 md:grid-cols-2">
            {section.items.map(item => (
              <a
                href={item.url}
                target="_blank"
                class="card transform hover:-translate-y-1 flex gap-3 items-center"
              > 
                <div class="w-15 h-15 flex justify-center items-center">
                  <img src={item.image} alt="tool logo" decoding="async" class="max-h-15" loading="lazy" />
                </div>
                <div class="flex flex-col group gap-1">
                  <h3 class="heading color-base hover:text-primary-500 text-lg">{item.name}</h3>
                  <p class="text-gray-600 dark:text-gray-400 switch-animation text-sm">{item.description}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>
