---
import ProjectPreview from '@components/ProjectPreview.astro'
import Layout from '@layouts/Layout.astro'
import { fetchProjects } from '@utils/project'

const projects = await fetchProjects()
---

<Layout title="项目" description="">
  <div class="space-y-16">
    <header class="space-y-4">
      <h1 class="heading text-4xl">项目</h1>
      <p class="text-gray-600 dark:text-gray-400 max-w-2xl">一些小玩意儿</p>
    </header>

    <div class="grid gap-8">
      {projects.map((project) => <ProjectPreview project={project} />)}
    </div>
  </div>
</Layout>
