---
import { Image } from 'astro:assets'
---

<div
  class="flex w-full flex-grow items-center gap-4 lg:flex-col lg:items-start lg:gap-0.5 lg:px-2"
>
  <div class="overflow-hidden rounded-full">
    <Image
      src="/logo.svg"
      width={40}
      height={40}
      decoding="async"
      loading="lazy"
      alt="softkern"
      class="duration-700 ease-in-out scale-100 blur-0 grayscale-0 rounded-full rotate-3 dark:border-neutral-600 lg:hover:scale-105"
      style="color:transparent"
    />
  </div>

  <div class="mt-1 flex items-center gap-2 lg:mt-4">
    <a href="/">
      <h2 class="flex-grow text-lg font-medium lg:text-xl">Softkern</h2></a
    >
    <svg
      stroke="currentColor"
      fill="currentColor"
      stroke-width="0"
      viewBox="0 0 24 24"
      class="text-blue-400"
      height="18"
      width="18"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path fill="none" d="M0 0h24v24H0z"></path><path
        d="M23 12l-2.44-2.79.34-3.69-3.61-.82-1.89-3.2L12 2.96 8.6 1.5 6.71 4.69 3.1 5.5l.34 3.7L1 12l2.44 2.79-.34 3.7 3.61.82L8.6 22.5l3.4-1.47 3.4 1.46 1.89-3.19 3.61-.82-.34-3.69L23 12zm-12.91 4.72l-3.8-3.81 1.48-1.48 2.32 2.33 5.85-5.87 1.48 1.48-7.33 7.35z"
      >
      </path>
    </svg>
  </div>

  <div
    class="hidden text-[15px] text-neutral-600 transition-all duration-300 hover:text-neutral-700 dark:text-neutral-500 dark:hover:text-neutral-400 lg:flex"
  >
    @softkern
  </div>
</div>
