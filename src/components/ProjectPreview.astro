---
import type { CollectionEntry } from 'astro:content'
import Card from './Card.astro'

interface Props {
  project: CollectionEntry<'projects'>
}

const { project } = Astro.props
---

<Card>
  <div class="flex flex-col h-full">
    <div class="flex items-center gap-2 mb-3">
      <h3 class="heading text-xl">
        <a 
          href={project.data.link}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-primary-500 themed"
        >
          {project.data.title}
        </a>
      </h3>
      {project.data.github && (
        <a
          href={project.data.github}
          class="text-gray-500 hover:text-gray-600 dark:text-gray-400 dark:hover:text-gray-300 themed"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="View source code on GitHub"
        >
          <div class="i-carbon-logo-github text-xl" />
        </a>
      )}
    </div>

    <p class="text-gray-600 dark:text-gray-400 mb-4 themed">{project.data.description}</p>

    {project.data.tags && (
      <div class="flex flex-wrap gap-2 mt-auto">
        {project.data.tags.map(tag => (
          <span class="px-2 py-1 text-sm rounded-md bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 themed">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</Card>
