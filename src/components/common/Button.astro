---
interface Props {
  variant?: 'primary' | 'secondary'
  class?: string
  href?: string
  rounded?: string
  compact?: boolean
}

const { variant = 'secondary', class: className, href, rounded = 'lg', compact = false } = Astro.props

const baseStyles = `inline-flex items-center gap-2 ${compact ? 'px-3 py-1' : 'px-4 py-2'} rounded-${rounded}`
const variants = {
  primary:
    'bg-neutral-200 dark:bg-neutral-600 text-neutral-500 dark:text-neutral-300 switch-animation hover:bg-neutral-600 dark:hover:bg-neutral-500',
  secondary: 'color-base bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 dark:hover:bg-gray-700',
}

const Element = href ? 'a' : 'button'
---

<Element href={href} class:list={[baseStyles, variants[variant], className]}>
  <slot />
</Element>
