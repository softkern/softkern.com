---
import { SITE } from 'config'
---

<section class="space-y-8">
  <div class="space-y-4">
    <h1 class="heading text-4xl md:text-5xl">
      你好，我是 <span class="text-primary-500">{SITE.author.name.toUpperCase()}</span>
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl">
      {SITE.author.bio}
    </p>
  </div>

  <div class="flex gap-4">
    <a href="/posts" class="btn dark:text-white text-black" aria-label="blog">
      查看文章
    </a>
    <a href="/about" class="btn" aria-label="about">
      关于
    </a>
  </div>
</section>
