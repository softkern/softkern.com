---
import { SITE } from 'config'
import Button from './Button.astro'
---

<section class="space-y-8">
  <div class="space-y-4">
    <h1 class="heading text-4xl md:text-5xl">
      你好，我是 <span class="color-mark">{SITE.author.name.toUpperCase()}</span>
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl bg-base">
      {SITE.author.bio}
    </p>
  </div>

  <div class="flex gap-4">
    <Button href="/posts" variant='primary'>
      查看文章
    </Button>

    <Button href='/about'>
      关于
    </Button>
  </div>
</section>
