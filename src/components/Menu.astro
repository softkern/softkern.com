---
import type { MenuItem } from '@types'
import { Icon } from 'astro-icon/components'

const menu: MenuItem[] = [
  {
    name: 'Home',
    url: '/',
    icon: 'carbon:home',
  },
  {
    name: 'Blog',
    url: '/posts',
    icon: 'carbon:rss',
  },
  {
    name: 'Projects',
    url: '/projects',
    icon: 'carbon:ibm-cloud-projects',
  },
  {
    name: 'Uses',
    url: '/uses',
    icon: 'carbon:tools-alt',
  },
  {
    name: 'About',
    url: '/about',
    icon: 'carbon:information',
  },
]

const currentPath = Astro.url.pathname
---

<nav class="flex flex-col space-y-1">
  {
    menu.map((item) => (
      <a href={item.url}>
        <div
          class:list={[
            "flex items-center gap-2 py-2 pl-4 pr-2.5 rounded-lg group",
            "text-neutral-700 hover:text-neutral-900 hover:bg-neutral-200 hover:lg:bg-neutral-200",
            "dark:text-neutral-400 hover:dark:text-neutral-300 hover:dark:lg:bg-neutral-800",
            currentPath.startsWith(item.url)
              ? "bg-neutral-200  text-neutral-900 dark:!text-neutral-200 dark:bg-neutral-800"
              : "",
          ]}
        >
          {item.icon && (
            <div
              class:list={[
                "group-hover:-rotate-12",
                currentPath.startsWith(item.url) ? "animate-pulse" : "",
              ]}
            >
              <Icon name={item.icon} height={20} width={20} />
            </div>
          )}

          <div class="ml-0.5 flex-grow">{item.name}</div>

          <Icon
            name="carbon:arrow-right"
            class:list={[currentPath.startsWith(item.url) ? "" : "hidden"]}
          />
        </div>
      </a>
    ))
  }
</nav>
